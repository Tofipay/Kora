# -----------------------------------------------------------------------------
# ToFi X Stream — نموذج متغيّرات البيئة
# انسخ هذا الملف إلى .env أو اضبط المتغيّرات في إعداد الخادم/الحاوية.
# كل القيم اختيارية ولها قيم افتراضية آمنة في config/config.php.
# -----------------------------------------------------------------------------

# التطبيق
APP_ENV=production            # production | development
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=http://localhost:8080 # العنوان العام الذي تُبنى منه روابط إعادة البثّ
APP_SECRET=change_me_to_a_long_random_secret_key   # مفتاح توقيع الروابط (إجباري في الإنتاج)

# مفتاح الـ API الإداري (لعمليات الكتابة في اللوحة/الـ API)
API_KEY=tofix_admin_key_change_me

# البروكسي
PROXY_MANIFEST_TTL=2
PROXY_TIMEOUT=20
# User-Agent الافتراضي للمصدر (VLC = الأكثر توافقًا مع IPTV). يمكن تجاوزه لكل قناة.
PROXY_UA="VLC/3.0.20 LibVLC/3.0.20"
# انتحال Referer/Origin — معطّل افتراضيًا (بعض سيرفرات IPTV ترفض Referer).
PROXY_SPOOF_REFERER=false
# الكاش ودمج الطلبات: اتصال واحد بالمصدر مهما بلغ عدد المشاهدين (مثالي لروابط IPTV أحادية الاتصال)
PROXY_CACHE=true
PROXY_SEGMENT_CACHE_TTL=120

# الأمن
SIGNED_URL_TTL=3600
HOTLINK_PROTECTION=false
ALLOWED_REFERERS=            # مثال: example.com,mysite.net
IP_ALLOWLIST=               # مثال: 1.2.3.4,5.6.7.8
RATE_LIMIT=true
RATE_LIMIT_MAX=600
RATE_LIMIT_WINDOW=60
