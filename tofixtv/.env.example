# ToFi X Tv — environment overrides (all optional; the site is domain-agnostic
# and works out of the box on any host with zero configuration).

# Fixed canonical base URL. Leave unset to derive it from the request host
# (HTTP_HOST) automatically — recommended.
#TOFIXTV_SITE_URL="https://tofi-xtv.com"

# TMDB bearer token for the movies & series section (a default is bundled;
# set your own to control quota).
#TMDB_BEARER_TOKEN=""

# Yacine channel resolver overrides (see app/config.php).
#YACINE_API_URL="http://ver3.yacinelive.com"
#YACINE_API_KEY=""
#YACINE_PROXY_SECRET=""
