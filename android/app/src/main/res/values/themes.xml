<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.TofiXTV" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Brand colors -->
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorPrimaryContainer">#CFF0EB</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorOnPrimaryContainer">@color/brand_primary_deep</item>
        <item name="colorSecondary">@color/brand_primary_dark</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorTertiary">@color/brand_accent</item>
        <item name="colorOnTertiary">@color/brand_ink</item>

        <item name="colorSurface">@color/surface_light</item>
        <item name="colorSurfaceVariant">@color/surface_variant_light</item>
        <item name="colorOnSurface">@color/on_surface_light</item>
        <item name="colorOnSurfaceVariant">@color/muted</item>
        <item name="android:colorBackground">@color/brand_bg</item>
        <item name="colorOutlineVariant">@color/divider</item>

        <item name="android:statusBarColor">@color/brand_primary_deep</item>
        <item name="android:navigationBarColor">@color/surface_light</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Typography: Cairo everywhere -->
        <item name="fontFamily">@font/cairo</item>
        <item name="android:fontFamily">@font/cairo</item>
        <item name="textAppearanceHeadlineSmall">@style/Text.HeadlineSmall</item>
        <item name="textAppearanceTitleLarge">@style/Text.TitleLarge</item>
        <item name="textAppearanceTitleMedium">@style/Text.TitleMedium</item>
        <item name="textAppearanceBodyLarge">@style/Text.BodyLarge</item>
        <item name="textAppearanceBodyMedium">@style/Text.BodyMedium</item>
        <item name="textAppearanceLabelLarge">@style/Text.LabelLarge</item>

        <!-- Shapes -->
        <item name="shapeAppearanceSmallComponent">@style/Shape.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/Shape.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/Shape.Large</item>

        <!-- Component styling -->
        <item name="materialCardViewStyle">@style/Card.Premium</item>
        <item name="bottomNavigationStyle">@style/BottomNav.Premium</item>
        <item name="materialButtonStyle">@style/Button.Premium</item>
    </style>

    <!-- Splash -->
    <style name="Theme.TofiXTV.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/brand_primary_deep</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.TofiXTV</item>
    </style>

    <!-- Premium elevated card -->
    <style name="Card.Premium" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">22dp</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">?attr/colorSurface</item>
        <item name="strokeColor">@color/divider</item>
        <item name="strokeWidth">1dp</item>
        <item name="contentPadding">14dp</item>
        <item name="rippleColor">#1A0D9488</item>
    </style>

    <style name="BottomNav.Premium" parent="Widget.Material3.BottomNavigationView">
        <item name="itemActiveIndicatorStyle">@style/BottomNav.Indicator</item>
        <item name="elevation">14dp</item>
        <item name="itemIconTint">@color/nav_item_tint</item>
        <item name="itemTextColor">@color/nav_item_tint</item>
        <item name="labelVisibilityMode">labeled</item>
    </style>

    <style name="BottomNav.Indicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">#2E0D9488</item>
    </style>

    <style name="Button.Premium" parent="Widget.Material3.Button">
        <item name="cornerRadius">16dp</item>
        <item name="android:textFontWeight">700</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <!-- Legacy alias kept for any references -->
    <style name="CardStyle" parent="Card.Premium" />
    <style name="ChipFilter" parent="Widget.Material3.Chip.Filter" />
</resources>
