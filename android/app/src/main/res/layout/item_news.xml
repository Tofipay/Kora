<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp" android:layout_marginVertical="6dp"
    app:cardCornerRadius="22dp" app:cardElevation="0dp"
    app:strokeColor="@color/divider"
    app:strokeWidth="1dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="10dp">
        <ImageView android:id="@+id/image" android:layout_width="110dp" android:layout_height="80dp"
            android:scaleType="centerCrop" android:contentDescription="@string/nav_news" />
        <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
            android:orientation="vertical" android:paddingHorizontal="10dp">
            <TextView android:id="@+id/title" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:maxLines="3" android:ellipsize="end" android:textStyle="bold" android:textSize="15sp" />
            <TextView android:id="@+id/time" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="6dp" android:textColor="@color/muted" android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
