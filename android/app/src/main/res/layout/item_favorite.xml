<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp" android:layout_marginVertical="5dp"
    app:cardCornerRadius="14dp" app:cardElevation="1dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical" android:padding="12dp">
        <ImageView android:id="@+id/logo" android:layout_width="40dp" android:layout_height="40dp"
            android:contentDescription="@string/nav_favorites" />
        <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
            android:orientation="vertical" android:paddingHorizontal="12dp">
            <TextView android:id="@+id/title" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:maxLines="1" android:ellipsize="end" android:textStyle="bold" />
            <TextView android:id="@+id/subtitle" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:maxLines="1" android:ellipsize="end" android:textColor="@color/muted" android:textSize="12sp" />
        </LinearLayout>
        <ImageView android:id="@+id/removeBtn" android:layout_width="26dp" android:layout_height="26dp"
            android:src="@drawable/ic_close" android:contentDescription="@string/nav_favorites" app:tint="@color/muted" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
