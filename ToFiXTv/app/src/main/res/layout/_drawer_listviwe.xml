<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="@drawable/bg_app_gradient"
	android:orientation="vertical">
	<LinearLayout
		android:id="@+id/linear4"
		android:layout_width="wrap_content"
		android:layout_height="match_parent"
		android:padding="16dp"
		android:gravity="center_horizontal|center_vertical"
		android:orientation="vertical">
		<ScrollView
			android:id="@+id/vscroll1"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:scrollbars="none">
			<LinearLayout
				android:id="@+id/linear2"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:padding="14dp"
				android:background="@drawable/bg_glass_card"
				android:gravity="center_horizontal|center_vertical"
				android:orientation="vertical"
				android:weightSum="5">
				<ImageView
					android:id="@+id/Privacy_Policy"
					android:layout_width="52dp"
					android:layout_height="52dp"
					android:padding="12dp"
					android:layout_marginTop="8dp"
					android:layout_marginBottom="8dp"
					android:src="@drawable/ic_ms_shield"
					android:contentDescription="@string/cd_privacy"
					android:scaleType="fitCenter"
					android:layout_gravity="center_horizontal|center_vertical"
					android:layout_weight="1"
					android:background="@drawable/ripple_glass_pill"
					android:clickable="true"
					android:focusable="true"
					 />
				<ImageView
					android:id="@+id/Location"
					android:layout_width="52dp"
					android:layout_height="52dp"
					android:padding="12dp"
					android:layout_marginTop="8dp"
					android:layout_marginBottom="8dp"
					android:src="@drawable/ic_ms_public"
					android:contentDescription="@string/cd_website"
					android:scaleType="fitCenter"
					android:layout_gravity="center_horizontal|center_vertical"
					android:layout_weight="1"
					android:background="@drawable/ripple_glass_pill"
					android:clickable="true"
					android:focusable="true"
					 />
				<ImageView
					android:id="@+id/Telegram"
					android:layout_width="52dp"
					android:layout_height="52dp"
					android:padding="12dp"
					android:layout_marginTop="8dp"
					android:layout_marginBottom="8dp"
					android:src="@drawable/ic_ms_send"
					android:contentDescription="@string/cd_telegram"
					android:scaleType="fitCenter"
					android:layout_gravity="center_horizontal"
					android:layout_weight="1"
					android:background="@drawable/ripple_glass_pill"
					android:clickable="true"
					android:focusable="true"
					 />
				<ImageView
					android:id="@+id/Rating"
					android:layout_width="52dp"
					android:layout_height="52dp"
					android:padding="12dp"
					android:layout_marginTop="8dp"
					android:layout_marginBottom="8dp"
					android:src="@drawable/ic_ms_star"
					android:contentDescription="@string/cd_rate"
					android:scaleType="fitCenter"
					android:layout_gravity="center_horizontal|center_vertical"
					android:layout_weight="1"
					android:background="@drawable/ripple_glass_pill"
					android:clickable="true"
					android:focusable="true"
					 />
				<ImageView
					android:id="@+id/Share"
					android:layout_width="52dp"
					android:layout_height="52dp"
					android:padding="12dp"
					android:layout_marginTop="8dp"
					android:layout_marginBottom="8dp"
					android:src="@drawable/ic_ms_share"
					android:contentDescription="@string/cd_share"
					android:scaleType="fitCenter"
					android:layout_gravity="center_horizontal|center_vertical"
					android:layout_weight="1"
					android:background="@drawable/ripple_glass_pill"
					android:clickable="true"
					android:focusable="true"
					 />
				<ImageView
					android:id="@+id/App"
					android:layout_width="52dp"
					android:layout_height="52dp"
					android:padding="12dp"
					android:layout_marginTop="8dp"
					android:layout_marginBottom="8dp"
					android:src="@drawable/ic_ms_apps"
					android:contentDescription="@string/cd_apps"
					android:scaleType="fitCenter"
					android:layout_gravity="center_horizontal|center_vertical"
					android:layout_weight="1"
					android:background="@drawable/ripple_glass_pill"
					android:clickable="true"
					android:focusable="true"
					 />
			</LinearLayout>
		</ScrollView>
	</LinearLayout>
</LinearLayout>
