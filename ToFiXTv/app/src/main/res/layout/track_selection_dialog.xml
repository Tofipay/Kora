<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:layout_margin="12dp"
    android:orientation="vertical"
    android:gravity="center"
    app:cardCornerRadius="24dp"
    app:cardElevation="20dp"
    app:cardMaxElevation="20dp"
    app:cardPreventCornerOverlap="true"
    app:cardUseCompatPadding="true"
    app:cardBackgroundColor="#A6101722">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="6dp"
        android:paddingBottom="10dp">

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/track_selection_dialog_tab_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            app:tabGravity="fill"
            app:tabMode="fixed"
            app:tabTextColor="#99FFFFFF"
            app:tabSelectedTextColor="#FFFFFFFF"
            app:tabRippleColor="#33FFFFFF"
            app:tabIndicatorColor="#3EB2FF"
            app:tabIndicatorHeight="3dp"
            app:tabIndicatorFullWidth="false"
            app:tabIndicatorGravity="bottom"
            app:tabTextAppearance="@style/TextAppearance.AppCompat.Button" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"
            android:background="#1FFFFFFF" />

        <androidx.viewpager.widget.ViewPager
            android:id="@+id/track_selection_dialog_view_pager"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:minHeight="120dp"
            android:maxHeight="260dp"
            android:layout_marginTop="4dp"
            android:paddingStart="6dp"
            android:paddingEnd="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end|center_vertical"
            android:paddingTop="10dp"
            android:paddingStart="6dp"
            android:paddingEnd="6dp">

            <Button
                android:id="@+id/track_selection_dialog_cancel_button"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="wrap_content"
                android:layout_height="46dp"
                android:minWidth="110dp"
                android:layout_marginEnd="10dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:singleLine="true"
                android:maxLines="1"
                android:ellipsize="none"
                android:includeFontPadding="false"
                android:text="@android:string/cancel"
                android:textColor="#CCFFFFFF"
                android:textAllCaps="false"
                android:textSize="15sp"
                android:background="@drawable/bg_track_dialog_cancel"
                android:foreground="?android:attr/selectableItemBackgroundBorderless" />

            <Button
                android:id="@+id/track_selection_dialog_ok_button"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="wrap_content"
                android:layout_height="46dp"
                android:minWidth="110dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:singleLine="true"
                android:maxLines="1"
                android:ellipsize="none"
                android:includeFontPadding="false"
                android:text="@android:string/ok"
                android:textColor="#FFFFFFFF"
                android:textAllCaps="false"
                android:textSize="15sp"
                android:background="@drawable/bg_track_dialog_ok"
                android:foreground="?android:attr/selectableItemBackgroundBorderless" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>