<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ===== ToFi X Tv 2026 — Material 3 Expressive, Dark-first, Arabic-first ===== -->
    <style name="AppTheme" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Brand color scheme -->
        <item name="colorPrimary">@color/tofi_primary</item>
        <item name="colorOnPrimary">@color/tofi_on_primary</item>
        <item name="colorPrimaryContainer">@color/tofi_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/tofi_on_primary_container</item>
        <item name="colorSecondary">@color/tofi_secondary</item>
        <item name="colorOnSecondary">@color/tofi_on_secondary</item>
        <item name="colorSecondaryContainer">@color/tofi_secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/tofi_on_secondary_container</item>
        <item name="colorTertiary">@color/tofi_dynamic_accent</item>
        <item name="colorError">@color/tofi_error</item>
        <item name="android:colorBackground">@color/tofi_background</item>
        <item name="colorSurface">@color/tofi_surface</item>
        <item name="colorOnSurface">@color/tofi_text_primary</item>
        <item name="colorSurfaceVariant">@color/tofi_surface_high</item>
        <item name="colorOnSurfaceVariant">@color/tofi_text_secondary</item>
        <item name="colorOutline">@color/tofi_outline</item>
        <item name="colorAccent">@color/tofi_primary</item>
        <item name="colorPrimaryDark">@color/tofi_background_deep</item>

        <!-- Typography: Tajawal (Arabic-first) -->
        <item name="android:fontFamily">@font/tajawal</item>
        <item name="fontFamily">@font/tajawal</item>

        <!-- Window -->
        <item name="android:windowBackground">@drawable/bg_app_gradient</item>
        <item name="android:statusBarColor">@color/tofi_status_bar</item>
        <item name="android:navigationBarColor">@color/tofi_nav_bar</item>
        <item name="android:windowContentTransitions">true</item>
        <item name="android:windowActivityTransitions">true</item>

        <!-- Controls -->
        <item name="colorControlHighlight">@color/tofi_ripple</item>
        <item name="android:textColorPrimary">@color/tofi_text_primary</item>
        <item name="android:textColorSecondary">@color/tofi_text_secondary</item>
        <item name="android:textColorHint">@color/tofi_text_hint</item>
    </style>

    <!-- شاشات ملء الشاشة (المشغل والخصوصية) -->
    <style name="AppTheme.FullScreen">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="AppTheme.AppBarOverlay" parent="ThemeOverlay.Material3.Dark.ActionBar">
        <item name="android:fontFamily">@font/tajawal</item>
        <item name="fontFamily">@font/tajawal</item>
    </style>

    <style name="AppTheme.PopupOverlay" parent="ThemeOverlay.Material3.Dark">
        <item name="android:fontFamily">@font/tajawal</item>
        <item name="fontFamily">@font/tajawal</item>
    </style>

    <!-- حوار اختيار الجودة/المسارات — زجاجي داكن -->
    <style name="TrackSelectionDialogThemeOverlay" parent="ThemeOverlay.AppCompat.Dialog.Alert">
        <item name="windowNoTitle">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:colorBackground">@color/tofi_surface</item>
        <item name="colorAccent">@color/tofi_primary</item>
        <item name="android:textColorPrimary">@color/tofi_text_primary</item>
        <item name="android:textColorSecondary">@color/tofi_text_secondary</item>
        <item name="android:fontFamily">@font/tajawal</item>
    </style>

    <!-- Typography scale 2026 -->
    <style name="TextAppearance.Tofi.Headline" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:fontFamily">@font/tajawal</item>
        <item name="android:textColor">@color/tofi_text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Tofi.Title" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:fontFamily">@font/tajawal</item>
        <item name="android:textColor">@color/tofi_text_primary</item>
    </style>

    <style name="TextAppearance.Tofi.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">@font/tajawal</item>
        <item name="android:textColor">@color/tofi_text_secondary</item>
    </style>

    <style name="TextAppearance.Tofi.Label" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:fontFamily">@font/tajawal</item>
        <item name="android:textColor">@color/tofi_text_secondary</item>
    </style>

</resources>
