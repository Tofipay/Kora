<?xml version="1.0" encoding="utf-8"?>
<!--
  Radial glow disc behind the main Play/Pause button so it reads as the hero control.
  The faint red core matches the ProgressBar tint (#B71C1C) that sits on top of it.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <gradient
        android:type="radial"
        android:gradientRadius="46dp"
        android:startColor="#59B71C1C"
        android:centerColor="#33000000"
        android:endColor="#00000000" />
    <stroke
        android:width="1dp"
        android:color="#33FFFFFF" />
</shape>
