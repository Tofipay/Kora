<?xml version="1.0" encoding="utf-8"?>
<!--
  Frosted-glass bottom control bar (Netflix / Disney+ / TiViMate / Android TV 2026 vibe).
  Translucent dark gradient, softly rounded top corners and a 1dp light hairline edge
  to fake the "glass" highlight. Works over any video because it is semi-transparent.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners
        android:topLeftRadius="26dp"
        android:topRightRadius="26dp" />
    <gradient
        android:angle="90"
        android:startColor="#F2121216"
        android:centerColor="#E617171C"
        android:endColor="#C21D1D24"
        android:type="linear" />
    <stroke
        android:width="1dp"
        android:color="#22FFFFFF" />
</shape>
