<?xml version="1.0" encoding="utf-8"?>
<!--
  Floating glass "pill" behind the center transport cluster
  (prev / rewind / play-pause / ffwd / next). Subtle translucent panel that groups
  the primary controls the way modern streaming players do.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners android:radius="44dp" />
    <gradient
        android:angle="90"
        android:startColor="#59000000"
        android:endColor="#40000000"
        android:type="linear" />
    <stroke
        android:width="1dp"
        android:color="#1FFFFFFF" />
</shape>
