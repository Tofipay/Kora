<?xml version="1.0" encoding="utf-8"?>
<!--
  Cinematic bottom scrim for the player overlay (Glassmorphism 2026).
  Darkens the lower portion of the video so controls stay legible on any frame.
  Applied to @id/exo_controls_background (which player code expands to full size).
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:angle="90"
        android:startColor="#CC000000"
        android:centerColor="#4D000000"
        android:centerY="0.55"
        android:endColor="#00000000"
        android:type="linear" />
</shape>
