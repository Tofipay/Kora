<!--
  ============================================================================
  Premium redesign · Glassmorphism UI/UX 2026
  ····························································································
  · No element removed · No android:id changed · Fully ExoPlayer-compatible.
  · Styles, dimens, includes, ProgressBar (@id/pb) and Track-Selection kept.
  · Companion drawables required (place in res/drawable):
        exo_controls_scrim.xml, exo_glass_bottom_bar_bg.xml,
        exo_center_controls_bg.xml, exo_play_glass_bg.xml
  · Dark by nature (overlay on video), scales to phones / tablets / Android TV.
  ============================================================================
-->
<merge xmlns:android="http://schemas.android.com/apk/res/android">

  <!-- 0dp dimensions are used to prevent this view from influencing the size of
       the parent view if it uses "wrap_content". It is expanded to occupy the
       entirety of the parent in code, after the parent's size has been
       determined. See: https://github.com/google/ExoPlayer/issues/8726.
       Background upgraded to a cinematic scrim so controls stay legible. -->
  <View android:id="@id/exo_controls_background"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:background="@drawable/exo_controls_scrim" />

  <FrameLayout android:id="@id/exo_bottom_bar"
      android:layout_width="match_parent"
      android:layout_height="@dimen/exo_styled_bottom_bar_height"
      android:layout_marginTop="@dimen/exo_styled_bottom_bar_margin_top"
      android:layout_gravity="bottom"
      android:background="@drawable/exo_glass_bottom_bar_bg"
      android:elevation="8dp"
      android:paddingStart="6dp"
      android:paddingEnd="6dp"
      android:clipToPadding="false"
      android:layoutDirection="ltr">

    <LinearLayout android:id="@id/exo_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/exo_styled_bottom_bar_time_padding"
        android:paddingEnd="@dimen/exo_styled_bottom_bar_time_padding"
        android:paddingLeft="@dimen/exo_styled_bottom_bar_time_padding"
        android:paddingRight="@dimen/exo_styled_bottom_bar_time_padding"
        android:layout_gravity="center_vertical|start"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layoutDirection="ltr">

      <TextView android:id="@id/exo_position"
          style="@style/ExoStyledControls.TimeText.Position"
          android:textColor="#FFFFFFFF"
          android:fontFamily="sans-serif-medium"
          android:letterSpacing="0.02"
          android:includeFontPadding="false"/>

      <TextView
          style="@style/ExoStyledControls.TimeText.Separator"
          android:textColor="#99FFFFFF"
          android:includeFontPadding="false"/>

      <TextView android:id="@id/exo_duration"
          style="@style/ExoStyledControls.TimeText.Duration"
          android:textColor="#B3FFFFFF"
          android:fontFamily="sans-serif-medium"
          android:letterSpacing="0.02"
          android:includeFontPadding="false"/>

    </LinearLayout>

   <LinearLayout
    android:id="@id/exo_basic_controls"
    android:layout_width="wrap_content"
    android:layout_height="match_parent"
    android:layout_gravity="center_vertical|end"
    android:orientation="horizontal"
    android:gravity="center"
    android:layoutDirection="ltr">


    <ImageButton
        android:id="@id/exo_subtitle"
        style="@style/ExoStyledControls.Button.Bottom.CC"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <ImageButton
        android:id="@id/exo_settings"
        style="@style/ExoStyledControls.Button.Bottom.Settings"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <ImageButton
        android:id="@+id/enser"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/enser"
        android:scaleType="centerInside"
        android:padding="12dp"
        android:layout_marginStart="2dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="Aspect ratio" />

    <ImageButton
        android:id="@+id/trackselection"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/track_select"
        android:scaleType="centerInside"
        android:padding="12dp"
        android:layout_marginStart="2dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="Track selection" />

     <ImageButton
        android:id="@+id/cast"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/cast"
        android:scaleType="centerInside"
        android:padding="12dp"
        android:layout_marginStart="2dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="Cast" />


    <ImageButton
        android:id="@+id/web_cast"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/web_cast"
        android:scaleType="centerInside"
        android:padding="12dp"
        android:layout_marginStart="2dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="Web cast" />


    <ImageButton
        android:id="@+id/pip"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_pip"
        android:scaleType="centerInside"
        android:padding="12dp"
        android:layout_marginStart="2dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="Picture in picture" />

    <ImageButton
        android:id="@+id/zoom"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/zoom"
        android:scaleType="centerInside"
        android:padding="12dp"
        android:layout_marginStart="2dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="Zoom" />

    <ImageButton
        android:id="@+id/orient"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/landscape"
        android:scaleType="centerInside"
        android:padding="12dp"
        android:layout_marginStart="2dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="Rotate screen" />




        <ImageButton
        android:id="@id/exo_vr"
        style="@style/ExoStyledControls.Button.Bottom.VR"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />


        <ImageButton
        android:id="@id/exo_shuffle"
        style="@style/ExoStyledControls.Button.Bottom.Shuffle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <ImageButton
        android:id="@id/exo_repeat_toggle"
        style="@style/ExoStyledControls.Button.Bottom.RepeatToggle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <ImageButton
        android:id="@id/exo_fullscreen"
        style="@style/ExoStyledControls.Button.Bottom.FullScreen"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <ImageButton
        android:id="@id/exo_overflow_show"
        style="@style/ExoStyledControls.Button.Bottom.OverflowShow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

   </LinearLayout>



    <HorizontalScrollView android:id="@id/exo_extra_controls_scroll_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical|end"
        android:visibility="invisible">

      <LinearLayout android:id="@id/exo_extra_controls"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:gravity="center_vertical"
          android:layoutDirection="ltr">

        <ImageButton android:id="@id/exo_overflow_hide"
            style="@style/ExoStyledControls.Button.Bottom.OverflowHide"/>

      </LinearLayout>

    </HorizontalScrollView>

  </FrameLayout>

  <View android:id="@id/exo_progress_placeholder"
      android:layout_width="match_parent"
      android:layout_height="@dimen/exo_styled_progress_layout_height"
      android:layout_gravity="bottom"
      android:layout_marginBottom="@dimen/exo_styled_progress_margin_bottom"/>

  <LinearLayout android:id="@id/exo_minimal_controls"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_gravity="bottom|end"
      android:layout_marginBottom="@dimen/exo_styled_minimal_controls_margin_bottom"
      android:orientation="horizontal"
      android:gravity="center_vertical"
      android:layoutDirection="ltr">

    <ImageButton android:id="@id/exo_minimal_fullscreen"
        style="@style/ExoStyledControls.Button.Bottom.FullScreen"/>

  </LinearLayout>

  <LinearLayout
    android:id="@id/exo_center_controls"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:background="@drawable/exo_center_controls_bg"
    android:elevation="6dp"
    android:gravity="center"
    android:padding="@dimen/exo_styled_controls_padding"
    android:paddingStart="10dp"
    android:paddingEnd="10dp"
    android:clipToPadding="false"
    android:layoutDirection="ltr">

    <ImageButton android:id="@id/exo_prev"
        style="@style/ExoStyledControls.Button.Center.Previous"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp" />

    <include layout="@layout/exo_player_control_rewind_button" />

    <!-- FrameLayout overlays the ProgressBar on the hero play/pause button.
         A radial glass disc sits behind it so it reads as the primary action. -->
    <FrameLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:layout_marginEnd="6dp"
        android:background="@drawable/exo_play_glass_bg"
        android:padding="4dp"
        android:clipToPadding="false">

        <ImageButton
            android:id="@id/exo_play_pause"
            style="@style/ExoStyledControls.Button.Center.PlayPause"
            android:layout_gravity="center" />

        <ProgressBar
            android:id="@+id/pb"
            style="?android:attr/progressBarStyle"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:indeterminate="true"
            android:indeterminateTint="#B71C1C"
            android:layout_gravity="center" />
    </FrameLayout>

    <include layout="@layout/exo_player_control_ffwd_button" />

    <ImageButton android:id="@id/exo_next"
        style="@style/ExoStyledControls.Button.Center.Next"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp" />

</LinearLayout>

</merge>
